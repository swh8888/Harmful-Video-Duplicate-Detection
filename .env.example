# Copy this file to .env and adjust as needed:  cp .env.example .env
# docker-compose reads .env automatically. All values have sensible
# defaults in docker-compose.yaml, so the stack also runs without a .env.
# The real .env is gitignored so credentials are never committed.

# --- PostgreSQL ---
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline
POSTGRES_DB=harmful_video

# --- MLflow (uses its own database to avoid an Alembic clash with Airflow) ---
MLFLOW_DB=mlflow_db

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_SECRET_KEY=harmful_video_secret
